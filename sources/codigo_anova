## Analisis de la eficiencia del uso de bloques
 
```{r}
#Modelo con bloques
modelo3 <- lm(incremento ~ bloque + harina * fermentador, data = datos)

#Modelo sin bloques
modelo4 <- lm(incremento ~ harina * fermentador, data = datos)

#Cuadrado medio residual
cmRESbloq <- anova(modelo3)["Residuals", "Mean Sq"]
cmRES <- anova(modelo4)["Residuals", "Mean Sq"]

#Eficiencia relativa
ER <- cmRES / cmRESbloq
ER_porcentaje <- ER * 100

ER
ER_porcentaje
```
